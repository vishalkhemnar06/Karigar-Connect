# Server environment variables for production deployment

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/karigarConnect?retryWrites=true&w=majority

# Server runtime
PORT=5000
HOST=0.0.0.0
JWT_SECRET=your_jwt_secret
INTERNAL_SECRET=your_internal_secret

# Service URLs
FRONTEND_URL=https://app.example.com
NODE_BASE_URL=https://api.example.com
FACE_SERVICE_URL=https://face.example.com
FRAUD_SERVICE_URL=https://fraud.example.com
SEMANTIC_SERVICE_URL=https://semantic.example.com

# Third-party integrations
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+919XXXXXXXXX
TWILIO_WEBHOOK_URL=https://api.example.com/api/ivr/twilio/voice
TWILIO_IVR_VOICE_PATH=/api/ivr/twilio/voice
TWILIO_IVR_STATE_PATH=/api/ivr/twilio/state
TWILIO_TTS_VOICE_HI=hi-IN-Chirp3-HD-Kore
TWILIO_TTS_VOICE_MR=mr-IN-Chirp3-HD-Kore
TWILIO_TTS_VOICE_EN=en-IN-Chirp3-HD-Kore

GROQ_API_KEY=
OPENAI_API_KEY=
GOOGLE_MAPS_API_KEY=

EMAIL_USER=
EMAIL_PASS=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

REGISTRATION_URL=https://app.example.com/register
IVR_JOB_MATCH_RADIUS_KM=20

# Optimize production behavior
DISABLE_DIRECT_HIRE_SWEEP=true
SKIP_SEMANTIC_REBUILD_ON_STARTUP=true
